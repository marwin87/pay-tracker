{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Read",
      "Edit",
      "Write",
      "Bash(uv run *)",
      "Bash(docker-compose up *)",
      "Bash(docker-compose ps *)",
      "Bash(docker-compose down *)",
      "Bash(docker-compose exec *)",
      "Bash(docker-compose logs *)",
      "Bash(python *)",
      "Bash(docker compose exec *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "test -d src/ && uv run black --quiet src/ tests/ || true",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "test -d src/ && uv run mypy src/ --no-error-summary || true",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
