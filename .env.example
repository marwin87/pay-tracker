# Deployment mode: LOCAL or CLOUD
DEPLOY_MODE=LOCAL

# --- LOCAL mode (PostgreSQL 17 runs inside the backend container) ---
POSTGRES_USER=paytracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=paytracker
DATABASE_URL=postgresql://paytracker:changeme@localhost:5432/paytracker

NEXT_PUBLIC_API_URL=http://localhost:8010

JWT_SECRET=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CLOUD mode (Supabase) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Reminders (optional, nice-to-have) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=changeme
# REMINDER_FROM=noreply@yourdomain.com
