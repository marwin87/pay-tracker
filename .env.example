POSTGRES_USER=paytracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=paytracker
# For local dev without Docker. In Docker Compose, the backend's DATABASE_URL is
# overridden via the environment: block in docker-compose.yml (host = postgres service name).
DATABASE_URL=postgresql://paytracker:changeme@localhost:5432/paytracker

NEXT_PUBLIC_API_URL=http://localhost:8010
NEXT_PUBLIC_APP_VERSION=dev

JWT_SECRET=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Reminders (optional, nice-to-have) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=changeme
# REMINDER_FROM=noreply@yourdomain.com

# --- Password reset ---
APP_BASE_URL=http://localhost:3010
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
